{"action": "vm_guest_exec", "actor": "operator", "audit_tag": null, "cmd": "qm guest exec 222 --timeout 20 -- sh -lc 'cat > /root/move-nvme-recovery.sh << '\"'\"'EOF'\"'\"'\n#!/bin/sh\nset -eu\nLOG=/root/nvme-recovery-move.log\nSRC_MNT=/mnt/nvme-recovery\nDEST_BASE=/var/lib/monero/nvme-recovery-backup-20260607\nDEST=$DEST_BASE/recovery\n{\n  echo \"[$(date -Is)] starting nvme recovery move\"\n  systemctl stop monero-wallet-rpc monero-alerter monerod || true\n  mkdir[REDACTED] \"$DEST_BASE\"\n  mountpoint -q \"$SRC_MNT\" || mount /dev/sdb \"$SRC_MNT\"\n  test -d \"$SRC_MNT/recovery/lmdb\"\n  echo \"[$(date -Is)] source df\"; df -hT \"$SRC_MNT\" /var/lib/monero\n  echo \"[$(date -Is)] source size\"; du -sh \"$SRC_MNT/recovery\"\n  mkdir[REDACTED]\n  echo \"[$(date -Is)] rsync start: $SRC_MNT/recovery/ -> $DEST/\"\n  rsync -aH --numeric-ids --info=progress2 \"$SRC_MNT/recovery/\" \"$DEST/\"\n  echo \"[$(date -Is)] rsync complete; syncing\"\n  sync\n  SRC_BYTES=$(du -sb \"$SRC_MNT/recovery\" | awk '\"'\"'{print $1}'\"'\"')\n  DST_BYTES=$(du -sb \"$DEST\" | awk '\"'\"'{print $1}'\"'\"')\n  echo \"[$(date -Is)] bytes source=$SRC_BYTES dest=$DST_BYTES\"\n  if [ \"$SRC_BYTES\" != \"$DST_BYTES\" ]; then\n    echo \"[$(date -Is)] ERROR byte mismatch; not deleting source\"\n    exit 2\n  fi\n  echo \"[$(date -Is)] removing source recovery from NVMe\"\n  rm -rf \"$SRC_MNT/recovery\"\n  sync\n  echo \"[$(date -Is)] final df\"; df -hT \"$SRC_MNT\" /var/lib/monero\n  echo \"[$(date -Is)] done\"\n  touch /root/nvme-recovery-move.done\n} >> \"$LOG\" 2>&1\nEOF\nchmod +x /root/move-nvme-recovery.sh\nrm -f /root/nvme-recovery-move.done\nnohup /root/move-nvme-recovery.sh >/dev/null 2>&1 &\necho started\n'", "result": {"cmd": "qm guest exec 222 --timeout 20 -- sh -lc 'cat > /root/move-nvme-recovery.sh << '\"'\"'EOF'\"'\"'\n#!/bin/sh\nset -eu\nLOG=/root/nvme-recovery-move.log\nSRC_MNT=/mnt/nvme-recovery\nDEST_BASE=/var/lib/monero/nvme-recovery-backup-20260607\nDEST=$DEST_BASE/recovery\n{\